# ===============================================
# SAT-Digital Backend - Configuración PRODUCCIÓN
# ===============================================
# Servidor: DWIN0540 (Web Server)
# Base de Datos: DWIN0293 (SQL Server 2016)
# Fecha: 2025-12-29
# ===============================================

# ==========================================
# ENTORNO Y SERVIDOR
# ==========================================
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ==========================================
# BASE DE DATOS - SQL SERVER 2016
# ==========================================
DB_TYPE=sqlserver

# SQL Server DWIN0293 - IP: 10.11.33.10
SQLSERVER_HOST=10.11.33.10
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=sat_digital_v2
SQLSERVER_USERNAME=calidad
SQLSERVER_PASSWORD=passcalidad
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_CERT=true
SQLSERVER_INSTANCE=

# Pool de Conexiones
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ==========================================
# JWT & SEGURIDAD
# ==========================================
# IMPORTANTE: Cambiar en producción con valores seguros
JWT_SECRET=SAT-Digital-2025-PRODUCCION-SECRET-KEY-CHANGE-ME-NOW
JWT_REFRESH_SECRET=SAT-Digital-2025-REFRESH-SECRET-KEY-CHANGE-ME-NOW
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Session Secret
SESSION_SECRET=SAT-Digital-Session-Secret-PRODUCCION-2025

# ==========================================
# CORS - FRONTEND
# ==========================================
# URL del servidor web DWIN0540
CORS_ORIGIN=http://10.75.247.181,http://sat-digital.local,http://localhost:5173
FRONTEND_URL=http://10.75.247.181

# ==========================================
# ARCHIVOS Y UPLOADS
# ==========================================
# Ruta absoluta en servidor DWIN0540
UPLOAD_PATH=D:\\webs\\SAT-DIGITAL\\backend\\uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,xlsx,xls,doc,docx

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
LOG_FILE=D:\\webs\\SAT-DIGITAL\\backend\\logs\\app.log
LOG_ERROR_FILE=D:\\webs\\SAT-DIGITAL\\backend\\logs\\error.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ==========================================
# WEBSOCKETS - SOCKET.IO
# ==========================================
SOCKET_CORS_ORIGIN=http://10.75.247.181,http://sat-digital.local
SOCKET_PATH=/socket.io
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# ==========================================
# NOTIFICACIONES - EMAIL
# ==========================================
# Configurar SMTP corporativo
SMTP_HOST=smtp.teco.com.ar
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=sat-digital@teco.com.ar
SMTP_PASS=CHANGE-ME
EMAIL_FROM=SAT-Digital <sat-digital@teco.com.ar>
EMAIL_REPLY_TO=soporte.sat@teco.com.ar

# ==========================================
# CACHE - REDIS (Opcional)
# ==========================================
# Si tienen Redis instalado en DWIN0540
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# INTEGRACIÓN ATERNITY (Inventario)
# ==========================================
ATERNITY_URL=https://us3-odata.aternity.com/aternity.odata/latest/
ATERNITY_USER=PJPalomanes@teco.com.ar
ATERNITY_PASSWORD=CHANGE-ME

# ==========================================
# IA - OLLAMA (Fase 3)
# ==========================================
# Configuración local de Ollama
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_VISION=llava
OLLAMA_MODEL_TEXT=llama3.1
OLLAMA_TIMEOUT=60000

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# TIMEZONE
# ==========================================
TZ=America/Argentina/Buenos_Aires

# ==========================================
# HEALTH CHECK
# ==========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
